<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <PublishProtocol>ClickOnce</PublishProtocol>
    <!-- Keep legacy VS publish host and .NET SDK ClickOnce on the same output root. -->
    <PublishUrl>bin\app.publish\</PublishUrl>
    <PublishDir>bin\app.publish\</PublishDir>
    <ClickOncePublishDir>bin\app.publish\</ClickOncePublishDir>
    <Install>true</Install>
    <ApplicationVersion>1.0.0.*</ApplicationVersion>
    <IsRevisionIncremented>True</IsRevisionIncremented>
    <UpdateEnabled>False</UpdateEnabled>
    <BootstrapperEnabled>True</BootstrapperEnabled>
    <MapFileExtensions>True</MapFileExtensions>
    <ApplicationRevision>0</ApplicationRevision>
    <IsWebBootstrapper>False</IsWebBootstrapper>
    <BootstrapperComponentsLocation>Relative</BootstrapperComponentsLocation>
    <SelfContained>False</SelfContained>
    <PublishSingleFile>False</PublishSingleFile>
    <PublishReadyToRun>False</PublishReadyToRun>
  </PropertyGroup>
</Project>
