<Application x:Class="ScreensView.Viewer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ScreensView.Viewer">
    <Application.Resources>
        <local:NullToBoolConverter x:Key="NullToBool"/>

        <!-- Shared palette -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#F9FBFD"/>
        <SolidColorBrush x:Key="AppSurfaceMutedBrush" Color="#EEF3F8"/>
        <SolidColorBrush x:Key="AppBorderBrush" Color="#D6DFEA"/>
        <SolidColorBrush x:Key="AppBorderStrongBrush" Color="#B9C7D6"/>
        <SolidColorBrush x:Key="AppTextBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="AppTextMutedBrush" Color="#5F6B7A"/>
        <SolidColorBrush x:Key="AppTextSubtleBrush" Color="#7A8796"/>
        <SolidColorBrush x:Key="AppAccentBrush" Color="#2F6FED"/>
        <SolidColorBrush x:Key="AppAccentHoverBrush" Color="#245BD1"/>
        <SolidColorBrush x:Key="AppAccentPressedBrush" Color="#1D49A6"/>
        <SolidColorBrush x:Key="AppAccentForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AppSuccessBrush" Color="#2E9F63"/>
        <SolidColorBrush x:Key="AppWarningBrush" Color="#C58A13"/>
        <SolidColorBrush x:Key="AppDangerBrush" Color="#C24C4C"/>
        <SolidColorBrush x:Key="AppSliderTrackBrush" Color="#C8D4E3"/>
        <SolidColorBrush x:Key="AppSliderThumbBrush" Color="#FFFFFF"/>

        <!-- Surface tokens -->
        <Thickness x:Key="AppControlPadding">14,8</Thickness>
        <Thickness x:Key="AppCompactControlPadding">10,6</Thickness>
        <CornerRadius x:Key="AppSurfaceCornerRadius">14</CornerRadius>
        <CornerRadius x:Key="AppControlCornerRadius">10</CornerRadius>
        <CornerRadius x:Key="AppPillCornerRadius">999</CornerRadius>
        <DropShadowEffect x:Key="AppSurfaceShadow"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Direction="270"
                          Opacity="0.10"
                          Color="#1A334A"/>

        <!-- Button styles -->
        <Style x:Key="AppButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Padding" Value="{StaticResource AppControlPadding}"/>
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource AppControlCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AppBorderStrongBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AppSurfaceMutedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AppButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AppAccentForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource AppControlCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AppAccentHoverBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AppAccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AppAccentPressedBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AppAccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppPollingToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="{StaticResource AppControlPadding}"/>
            <Setter Property="Background" Value="{StaticResource AppAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource AppAccentForegroundBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource AppPillCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.96"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource AppDangerBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AppDangerBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Background" Value="{StaticResource AppAccentBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input styles -->
        <Style x:Key="AppCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Box"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="4"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource AppBorderStrongBrush}"
                                    Background="{StaticResource AppSurfaceBrush}"
                                    VerticalAlignment="Center"/>
                            <Path x:Name="CheckMark"
                                  Grid.Column="0"
                                  Data="M 3 8 L 6 11 L 13 4"
                                  Stroke="{StaticResource AppAccentBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#E9F1FF"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AppAccentBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AppAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppSliderStyle" TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Track x:Name="PART_Track"
                                   Grid.Column="1"
                                   Focusable="False"
                                   IsDirectionReversed="{TemplateBinding IsDirectionReversed}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Value="{TemplateBinding Value}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="{StaticResource AppAccentBrush}"
                                                  BorderThickness="0"
                                                  Height="4"
                                                  IsHitTestVisible="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="{StaticResource AppSliderTrackBrush}"
                                                  BorderThickness="0"
                                                  Height="4"
                                                  IsHitTestVisible="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14"
                                           Height="14"
                                           Background="{StaticResource AppSliderThumbBrush}"
                                           BorderBrush="{StaticResource AppAccentBrush}"
                                           BorderThickness="1"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Surface styles -->
        <Style x:Key="AppCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource AppSurfaceCornerRadius}"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect" Value="{StaticResource AppSurfaceShadow}"/>
        </Style>

        <Style x:Key="AppSummarySurfaceStyle" TargetType="Border" BasedOn="{StaticResource AppCardBorderStyle}">
            <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <!-- Text helpers -->
        <Style x:Key="AppTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="AppSectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="AppBodyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AppTextBrush}"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>

        <Style x:Key="AppMutedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource AppBodyTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource AppTextMutedBrush}"/>
        </Style>

        <Style x:Key="AppCaptionTextStyle" TargetType="TextBlock" BasedOn="{StaticResource AppBodyTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource AppTextSubtleBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Application.Resources>
</Application>
