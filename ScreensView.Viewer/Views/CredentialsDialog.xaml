<Window x:Class="ScreensView.Viewer.Views.CredentialsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учетные данные"
        Width="420"
        Height="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Укажите учетные данные администратора для удаленной установки агента."
                   TextWrapping="Wrap" />

        <CheckBox x:Name="UseCurrentCredsBox"
                  Grid.Row="1"
                  Margin="0,12,0,0"
                  Content="Использовать текущую учетную запись"
                  IsChecked="True"
                  Checked="CurrentCreds_Changed"
                  Unchecked="CurrentCreds_Changed" />

        <StackPanel x:Name="ManualCredsPanel"
                    Grid.Row="2"
                    Margin="0,12,0,0"
                    Visibility="Collapsed">
            <TextBlock Text="Имя пользователя" />
            <TextBox x:Name="UsernameBox"
                     Margin="0,4,0,12" />
            <TextBlock Text="Пароль" />
            <PasswordBox x:Name="PasswordBox"
                         Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="96"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Ok_Click"
                    Content="OK" />
            <Button Width="96"
                    IsCancel="True"
                    Content="Отмена" />
        </StackPanel>
    </Grid>
</Window>
