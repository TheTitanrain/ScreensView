<Window x:Class="ScreensView.Viewer.Views.ConnectionsFilePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пароль файла подключений"
        MinHeight="260"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" FontSize="16" FontWeight="SemiBold"/>
        <TextBlock x:Name="TxtPath" Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#4B5563"/>

        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock Text="{DynamicResource Str.Password.PasswordLabel}"/>
            <PasswordBox x:Name="PasswordInput" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel x:Name="ConfirmPanel" Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Text="{DynamicResource Str.Password.ConfirmLabel}"/>
            <PasswordBox x:Name="ConfirmPasswordInput" Margin="0,6,0,0"/>
        </StackPanel>

        <CheckBox x:Name="RememberPasswordCheckBox"
                  Grid.Row="4"
                  Margin="0,16,0,0"
                  Content="{DynamicResource Str.Password.Remember}"/>

        <TextBlock x:Name="RememberPasswordHint"
                   Grid.Row="5"
                   Margin="0,16,0,0"
                   TextWrapping="Wrap"
                   Foreground="#4B5563"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Content="{DynamicResource Str.Password.BtnCancel}"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button x:Name="OkButton"
                    Content="{DynamicResource Str.Password.BtnOk}"
                    Width="90"
                    IsDefault="True"
                    Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
