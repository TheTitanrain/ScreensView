<Window x:Class="ScreensView.Viewer.Views.AddEditComputerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Компьютер" Height="380" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <StackPanel Margin="16">
        <Label Content="Имя компьютера:"/>
        <TextBox x:Name="NameBox" Margin="0,0,0,8"/>

        <Label Content="Хост / IP-адрес:"/>
        <TextBox x:Name="HostBox" Margin="0,0,0,8"/>

        <Label Content="Порт:"/>
        <TextBox x:Name="PortBox" Margin="0,0,0,8" Text="5443"/>

        <Label Content="API-ключ:"/>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ApiKeyBox" Grid.Column="0"/>
            <Button Grid.Column="1" Content="Сгенерировать" Margin="4,0,0,0" Click="Generate_Click"/>
        </Grid>

        <CheckBox x:Name="EnabledCheck" Content="Включён" IsChecked="True" Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button Content="Отмена" Width="80" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
