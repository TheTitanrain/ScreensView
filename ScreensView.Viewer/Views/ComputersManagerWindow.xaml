<Window x:Class="ScreensView.Viewer.Views.ComputersManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление компьютерами" Height="480" Width="730"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="ToolbarSeparator" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Fill" Value="#D0D0D0"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="White" BorderBrush="#D0D0D0" BorderThickness="1"
                                CornerRadius="5" Padding="5,6,12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F0F0F0"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#D8D8D8"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Height="44"
                Background="#F3F3F3"
                BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">

                <Button x:Name="BtnAdd" Style="{StaticResource ToolbarButton}" Click="Add_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Добавить" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnAddMultiple" Style="{StaticResource ToolbarButton}" Click="AddMultiple_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FA;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Добавить несколько" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnEdit" Style="{StaticResource ToolbarButton}" Click="Edit_Click" IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Редактировать" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnDelete" Style="{StaticResource ToolbarButton}" Click="Delete_Click" IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Удалить" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Rectangle Style="{StaticResource ToolbarSeparator}"/>

                <Button x:Name="BtnInstall" Style="{StaticResource ToolbarButton}" Click="Install_Click" IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE896;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Установить агент" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnUninstall" Style="{StaticResource ToolbarButton}" Click="Uninstall_Click" IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8BB;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Удалить агент" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Rectangle Style="{StaticResource ToolbarSeparator}"/>

                <Button x:Name="BtnUpdateAllAgents" Style="{StaticResource ToolbarButton}" Click="UpdateAllAgents_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Обновить агентов" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Margin="4,4,4,0" Padding="8" CornerRadius="6" Background="#F3F5F7" BorderBrush="#D7DCE2" BorderThickness="1">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="Источник подключений" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtConnectionsSource" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnConnectionsFile" Style="{StaticResource ToolbarButton}" Margin="8,0,4,0" Click="ConnectionsFile_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text=" Файл подключений..." VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnUseLocal" Style="{StaticResource ToolbarButton}" Click="UseLocal_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text=" Использовать локальный файл" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- List -->
        <ListView x:Name="ComputersList" SelectionMode="Extended" SelectionChanged="ComputersList_SelectionChanged" Margin="4">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Включён" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                          Click="EnabledCheckBox_Click"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Имя" Width="160" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Хост / IP" Width="160" DisplayMemberBinding="{Binding Host}"/>
                    <GridViewColumn Header="Порт" Width="60" DisplayMemberBinding="{Binding Port}"/>
                    <GridViewColumn Header="Статус" Width="80" DisplayMemberBinding="{Binding Status}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
