<Window x:Class="ScreensView.Viewer.Views.ComputersManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление компьютерами" Height="480" Width="680"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <DockPanel>
        <!-- Toolbar at top -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button x:Name="BtnAdd" Content="Добавить" Padding="8,3" Margin="2,0" Click="Add_Click"/>
                <Button x:Name="BtnAddMultiple" Content="Добавить несколько" Padding="8,3" Margin="2,0" Click="AddMultiple_Click"/>
                <Button x:Name="BtnEdit" Content="Редактировать" Padding="8,3" Margin="2,0" Click="Edit_Click" IsEnabled="False"/>
                <Button x:Name="BtnDelete" Content="Удалить" Padding="8,3" Margin="2,0" Click="Delete_Click" IsEnabled="False"/>
                <Separator/>
                <Button x:Name="BtnInstall" Content="Установить агент" Padding="8,3" Margin="2,0" Click="Install_Click" IsEnabled="False"/>
                <Button x:Name="BtnUninstall" Content="Удалить агент" Padding="8,3" Margin="2,0" Click="Uninstall_Click" IsEnabled="False"/>
            </ToolBar>
        </ToolBarTray>

        <!-- List -->
        <ListView x:Name="ComputersList" SelectionMode="Extended" SelectionChanged="ComputersList_SelectionChanged" Margin="4">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Имя" Width="160" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Хост / IP" Width="160" DisplayMemberBinding="{Binding Host}"/>
                    <GridViewColumn Header="Порт" Width="60" DisplayMemberBinding="{Binding Port}"/>
                    <GridViewColumn Header="Статус" Width="80" DisplayMemberBinding="{Binding Status}"/>
                    <GridViewColumn Header="Включён" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled}" IsEnabled="False" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
