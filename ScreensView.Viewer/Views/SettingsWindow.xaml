<Window x:Class="ScreensView.Viewer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ScreensView.Viewer.Models"
        Title="Настройки" Height="380" Width="420"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section header -->
        <TextBlock Grid.Row="0" Text="Распознавание экрана" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,12"/>

        <!-- Settings content -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <!-- Enable toggle -->
            <CheckBox IsChecked="{Binding IsLlmEnabled}" Content="Включить распознавание экрана" Margin="0,0,0,12"/>

            <!-- Interval -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Интервал проверок:" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <Slider Value="{Binding LlmCheckIntervalMinutes}" Minimum="1" Maximum="60"
                            TickFrequency="1" IsSnapToTickEnabled="True" Width="240" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LlmCheckIntervalMinutes, StringFormat='{}{0} мин'}"
                               Margin="8,0,0,0" VerticalAlignment="Center" MinWidth="50"/>
                </StackPanel>
            </StackPanel>

            <!-- Model selection -->
            <StackPanel Margin="0,0,0,4">
                <TextBlock Text="Модель:" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{x:Static models:ModelDefinition.Available}"
                          SelectedItem="{Binding SelectedModel}"
                          DisplayMemberPath="DisplayName"
                          HorizontalAlignment="Stretch">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DownloadModelCommand.IsRunning}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>
            </StackPanel>

            <!-- Model status -->
            <TextBlock Text="{Binding ModelStatusText}" Foreground="Gray" Margin="0,4,0,12"/>

            <!-- Download progress bar — visible only during download -->
            <ProgressBar Value="{Binding ModelDownloadProgress, Mode=OneWay}" Minimum="0" Maximum="100"
                         Height="6" Margin="0,0,0,8">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ModelDownloadProgress,
                                Converter={StaticResource ModelDownloadActive}}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>

            <!-- Download percentage text — visible only during download -->
            <TextBlock Margin="0,0,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DownloadModelCommand.IsRunning}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Text="{Binding ModelDownloadProgress, Mode=OneWay, StringFormat='{}{0:0}%'}"/>
            </TextBlock>

            <!-- Download / Cancel buttons -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Скачать" Command="{Binding DownloadModelCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Отмена" Command="{Binding DownloadModelCancelCommand}" Padding="12,4">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DownloadModelCommand.IsRunning}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- Close button row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Закрыть" IsCancel="True" Padding="16,4"/>
        </StackPanel>
    </Grid>
</Window>
