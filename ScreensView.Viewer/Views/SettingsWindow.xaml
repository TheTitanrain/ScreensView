<Window x:Class="ScreensView.Viewer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ScreensView.Viewer.Models"
        Title="Настройки" Height="760" Width="680"
        MinWidth="560" MinHeight="620"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Настройки Viewer" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Все постоянные настройки собраны в одном окне. Изменения применяются сразу."
                       Margin="0,6,0,0"
                       Foreground="#666666"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="14" Margin="0,0,0,12" CornerRadius="8"
                        Background="#F5F7FA" BorderBrush="#D8DDE5" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Общие" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Параметры обновления списка и поведение Viewer при входе в Windows."
                                   Margin="0,4,0,12"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Интервал обновления:" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <Slider Value="{Binding RefreshInterval}" Minimum="1" Maximum="60"
                                        TickFrequency="1" IsSnapToTickEnabled="True" Width="280" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding RefreshInterval, StringFormat='{}{0} с'}"
                                           Margin="8,0,0,0" VerticalAlignment="Center" MinWidth="44"/>
                            </StackPanel>
                        </StackPanel>

                        <CheckBox IsChecked="{Binding IsAutostartEnabled}"
                                  Content="Автозапуск при входе в Windows"/>
                    </StackPanel>
                </Border>

                <Border Padding="14" Margin="0,0,0,12" CornerRadius="8"
                        Background="#F5F7FA" BorderBrush="#D8DDE5" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Распознавание экрана" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Настройки LLM-проверки скриншотов и локального backend для llama-server."
                                   Margin="0,4,0,12"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"/>

                        <CheckBox IsChecked="{Binding IsLlmEnabled}"
                                  Content="Включить распознавание экрана"
                                  Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Интервал проверок:" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <Slider Value="{Binding LlmCheckIntervalMinutes}" Minimum="1" Maximum="60"
                                        TickFrequency="1" IsSnapToTickEnabled="True" Width="280" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding LlmCheckIntervalMinutes, StringFormat='{}{0} мин'}"
                                           Margin="8,0,0,0" VerticalAlignment="Center" MinWidth="56"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="Модель:" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{x:Static models:ModelDefinition.Available}"
                                      SelectedItem="{Binding SelectedModel}"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DownloadModelCommand.IsRunning}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Text="{Binding ModelStatusText}" Foreground="Gray" Margin="0,4,0,12"/>

                        <ProgressBar Value="{Binding ModelDownloadProgress, Mode=OneWay}"
                                     Minimum="0" Maximum="100"
                                     Height="6"
                                     Margin="0,0,0,8">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModelDownloadProgress, Converter={StaticResource ModelDownloadActive}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>

                        <TextBlock Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModelDownloadProgress, Converter={StaticResource ModelDownloadActive}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding ModelDownloadProgress, Mode=OneWay, StringFormat='{}{0:0}%'}"/>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Скачать" Command="{Binding DownloadModelCommand}" Padding="12,4" Margin="0,0,8,0"/>
                            <Button Content="Отмена" Command="{Binding DownloadModelCancelCommand}" Padding="12,4">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DownloadModelCommand.IsRunning}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <Separator Margin="0,0,0,12"/>

                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="Бэкенд llama-server:" Margin="0,0,0,4"/>
                            <ComboBox SelectedValue="{Binding SelectedBackend}" SelectedValuePath="Tag"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.Style>
                                    <Style TargetType="ComboBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DownloadBinaryCommand.IsRunning}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.Style>
                                <ComboBoxItem Tag="cpu" Content="CPU"/>
                                <ComboBoxItem Tag="vulkan" Content="Vulkan (AMD / Intel)"/>
                                <ComboBoxItem Tag="cuda" Content="CUDA (NVIDIA)"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Text="{Binding BinaryStatusText}" Foreground="Gray" Margin="0,4,0,12"/>

                        <ProgressBar Value="{Binding BinaryDownloadProgress, Mode=OneWay}"
                                     Minimum="0" Maximum="100"
                                     Height="6"
                                     Margin="0,0,0,8">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BinaryDownloadProgress, Converter={StaticResource ModelDownloadActive}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>

                        <TextBlock Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BinaryDownloadProgress, Converter={StaticResource ModelDownloadActive}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding BinaryDownloadProgress, Mode=OneWay, StringFormat='{}{0:0}%'}"/>
                        </TextBlock>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Скачать бэкенд" Command="{Binding DownloadBinaryCommand}" Padding="12,4" Margin="0,0,8,0"/>
                            <Button Content="Отмена" Command="{Binding DownloadBinaryCancelCommand}" Padding="12,4">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DownloadBinaryCommand.IsRunning}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Padding="14" CornerRadius="8"
                        Background="#F5F7FA" BorderBrush="#D8DDE5" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Хранилище подключений" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Выберите, где хранится список компьютеров: локально или во внешнем зашифрованном файле."
                                   Margin="0,4,0,12"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Текущий источник" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtConnectionsSource" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtConnectionsHint" Margin="0,6,0,12" Foreground="#666666" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Файл подключений..."
                                    Padding="12,4"
                                    Margin="0,0,8,0"
                                    Click="ConnectionsFile_Click"/>
                            <Button x:Name="BtnUseLocal"
                                    Content="Использовать локальный файл"
                                    Padding="12,4"
                                    Click="UseLocal_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Закрыть" IsCancel="True" Padding="16,4"/>
        </StackPanel>
    </Grid>
</Window>
