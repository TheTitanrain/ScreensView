<Window x:Class="ScreensView.Viewer.Views.ScreenshotZoomWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScreensView.Viewer.ViewModels"
        Title="ScreensView — Zoom"
        WindowStyle="None"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        AllowsTransparency="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Screenshot -->
        <Image Grid.Row="0" Source="{Binding Screenshot}" Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Placeholder when no screenshot -->
        <TextBlock Grid.Row="0" Text="Нет изображения" Foreground="#666"
                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Screenshot, Converter={StaticResource NullToBool}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Lock overlay -->
        <Grid Grid.Row="0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Locked">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Rectangle Fill="#80000000"/>
            <TextBlock Text="🔒" FontSize="64"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White"/>
        </Grid>

        <!-- Close button -->
        <Button Grid.Row="0" Content="✕" Width="36" Height="36"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,8,0" Panel.ZIndex="1"
                Click="CloseButton_Click"
                Background="#3A3A3A" Foreground="White" BorderThickness="0"
                FontSize="16" Cursor="Hand"/>

        <!-- Bottom bar -->
        <Border Grid.Row="1" Background="#2D2D2D">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status indicator -->
                <Ellipse Grid.Column="0" Width="10" Height="10"
                         Margin="8,0,0,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="Gray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Online">
                                    <Setter Property="Fill" Value="#44CC44"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Offline">
                                    <Setter Property="Fill" Value="#CC4444"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                    <Setter Property="Fill" Value="#CCAA00"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Locked">
                                    <Setter Property="Fill" Value="#CCAA44"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                    <Setter Property="Fill" Value="#7B8A97"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <!-- Computer name -->
                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White"
                           VerticalAlignment="Center" Margin="6,0" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" ToolTip="{Binding StatusMessage}"/>

                <!-- Last updated time -->
                <TextBlock Grid.Column="2" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#888"/>
                            <Setter Property="Text" Value="{Binding LastUpdated, StringFormat='HH:mm:ss'}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                    <Setter Property="Foreground" Value="#B5C0C9"/>
                                    <Setter Property="Text" Value="Откл."/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
