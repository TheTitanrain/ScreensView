<Window x:Class="ScreensView.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScreensView.Viewer.ViewModels"
        Title="ScreensView"
        Width="1100"
        Height="700"
        Background="{StaticResource AppBackgroundBrush}"
        Icon="/screensview.ico"
        WindowState="Maximized"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="SummaryValueTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource AppTitleTextStyle}">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatusIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Fill" Value="{StaticResource AppBorderStrongBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Online">
                    <Setter Property="Fill" Value="{StaticResource AppSuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Offline">
                    <Setter Property="Fill" Value="{StaticResource AppDangerBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Error">
                    <Setter Property="Fill" Value="{StaticResource AppWarningBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Locked">
                    <Setter Property="Fill" Value="{StaticResource AppWarningBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComputerCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource AppCardBorderStyle}">
            <Setter Property="Width" Value="332"/>
            <Setter Property="Height" Value="274"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AppBorderStrongBrush}"/>
                    <Setter Property="Background" Value="{StaticResource AppSurfaceRaisedBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.72"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,14"
                Style="{StaticResource AppCardBorderStyle}"
                Padding="20">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="ScreensView"
                                   Style="{StaticResource AppTitleTextStyle}"
                                   FontSize="26"/>
                        <TextBlock Margin="0,6,0,0"
                                   Text="Лёгкая панель мониторинга подключённых компьютеров"
                                   Style="{StaticResource AppMutedTextStyle}"/>
                    </StackPanel>

                    <WrapPanel Grid.Column="1"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top">
                        <Button Margin="0,0,10,10"
                                Click="ManageComputers_Click"
                                Content="Управление компьютерами"
                                Style="{StaticResource AppButtonStyle}"/>
                        <Button Margin="0,0,10,10"
                                Click="UpdateAllAgents_Click"
                                Content="Обновить агентов"
                                Style="{StaticResource AppPrimaryButtonStyle}"/>
                        <Button Margin="0,0,0,10"
                                Click="About_Click"
                                Content="О программе"
                                Style="{StaticResource AppButtonStyle}"/>
                    </WrapPanel>
                </Grid>

                <WrapPanel>
                    <Border Margin="0,0,12,12"
                            Style="{StaticResource AppSummarySurfaceStyle}"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Интервал обновления"
                                       Style="{StaticResource AppCaptionTextStyle}"/>
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <Slider x:Name="IntervalSlider"
                                        Width="180"
                                        Minimum="1"
                                        Maximum="60"
                                        IsSnapToTickEnabled="True"
                                        Style="{StaticResource AppSliderStyle}"
                                        TickFrequency="1"
                                        Value="{Binding RefreshInterval}"/>
                                <TextBlock Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="{Binding RefreshInterval, StringFormat='{}{0} с'}"
                                           Style="{StaticResource AppSectionHeaderTextStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ToggleButton Margin="0,0,12,12"
                                  Command="{Binding TogglePollingCommand}"
                                  IsChecked="{Binding IsPolling, Mode=OneWay}">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton"
                                   BasedOn="{StaticResource AppPollingToggleButtonStyle}">
                                <Setter Property="Content" Value="Запустить опрос"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="Остановить опрос"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <Border Margin="0,0,12,12"
                            Style="{StaticResource AppSummarySurfaceStyle}"
                            Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Параметры запуска"
                                       Style="{StaticResource AppCaptionTextStyle}"/>
                            <CheckBox Margin="0,8,0,0"
                                      Content="Автозапуск"
                                      IsChecked="{Binding IsAutostartEnabled}"
                                      Style="{StaticResource AppCheckBoxStyle}"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.25*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Style="{StaticResource AppSummarySurfaceStyle}">
                <StackPanel>
                    <Border Width="40"
                            Height="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AppAccentBrush}"
                            CornerRadius="{StaticResource AppPillCornerRadius}"/>
                    <TextBlock Margin="0,12,0,6"
                               Text="Активные компьютеры"
                               Style="{StaticResource AppCaptionTextStyle}"/>
                    <TextBlock Text="{Binding ActiveComputerCount}"
                               Style="{StaticResource SummaryValueTextStyle}"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="Участвуют в текущем мониторинге"
                               Style="{StaticResource AppMutedTextStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,0,12,0"
                    Style="{StaticResource AppSummarySurfaceStyle}">
                <StackPanel>
                    <Border Width="40"
                            Height="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AppSuccessBrush}"
                            CornerRadius="{StaticResource AppPillCornerRadius}"/>
                    <TextBlock Margin="0,12,0,6"
                               Text="Онлайн"
                               Style="{StaticResource AppCaptionTextStyle}"/>
                    <TextBlock Text="{Binding OnlineComputerCount}"
                               Style="{StaticResource SummaryValueTextStyle}"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="Получают свежие снимки экрана"
                               Style="{StaticResource AppMutedTextStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Margin="0,0,12,0"
                    Style="{StaticResource AppSummarySurfaceStyle}">
                <StackPanel>
                    <Border Width="40"
                            Height="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AppWarningBrush}"
                            CornerRadius="{StaticResource AppPillCornerRadius}"/>
                    <TextBlock Margin="0,12,0,6"
                               Text="Проблемы"
                               Style="{StaticResource AppCaptionTextStyle}"/>
                    <TextBlock Text="{Binding ProblemComputerCount}"
                               Style="{StaticResource SummaryValueTextStyle}"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="Нет сети или возникла ошибка опроса"
                               Style="{StaticResource AppMutedTextStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Style="{StaticResource AppSummarySurfaceStyle}">
                <StackPanel>
                    <Border Width="40"
                            Height="4"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AppBorderStrongBrush}"
                            CornerRadius="{StaticResource AppPillCornerRadius}"/>
                    <TextBlock Margin="0,12,0,8"
                               Text="Состояние опроса"
                               Style="{StaticResource AppCaptionTextStyle}"/>
                    <TextBlock Text="{Binding PollingStateText}"
                               TextWrapping="Wrap"
                               Style="{StaticResource AppSectionHeaderTextStyle}"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding RefreshInterval, StringFormat='Интервал: {0} сек.'}"
                               Style="{StaticResource AppMutedTextStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Computers}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ComputerViewModel}">
                        <Border MouseLeftButtonDown="Card_MouseLeftButtonDown"
                                Style="{StaticResource ComputerCardStyle}"
                                ToolTip="{Binding StatusText}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="184"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Margin="14,14,14,0"
                                        Background="{StaticResource AppSurfaceMutedBrush}"
                                        BorderBrush="{StaticResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <Image Source="{Binding Screenshot}"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="LowQuality"/>

                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasScreenshot}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <Border Width="54"
                                                    Height="54"
                                                    Margin="0,0,0,12"
                                                    Background="{StaticResource AppSurfaceBrush}"
                                                    BorderBrush="{StaticResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="27">
                                                <Grid>
                                                    <Rectangle Width="22"
                                                               Height="15"
                                                               RadiusX="3"
                                                               RadiusY="3"
                                                               Stroke="{StaticResource AppBorderStrongBrush}"
                                                               StrokeThickness="1.5"/>
                                                    <Rectangle Width="8"
                                                               Height="2"
                                                               Margin="0,13,0,0"
                                                               Fill="{StaticResource AppBorderStrongBrush}"
                                                               VerticalAlignment="Top"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock HorizontalAlignment="Center"
                                                       Text="Нет изображения"
                                                       Style="{StaticResource AppSectionHeaderTextStyle}"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       HorizontalAlignment="Center"
                                                       Text="Снимок появится после следующего опроса"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Style="{StaticResource AppCaptionTextStyle}"/>
                                        </StackPanel>

                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Locked">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <Border Background="#A6F4F7FB"
                                                    CornerRadius="12"/>
                                            <Border HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="#FDFEFF"
                                                    BorderBrush="{StaticResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="16,12">
                                                <StackPanel>
                                                    <TextBlock HorizontalAlignment="Center"
                                                               Text="Сеанс заблокирован"
                                                               Style="{StaticResource AppSectionHeaderTextStyle}"/>
                                                    <TextBlock Margin="0,4,0,0"
                                                               HorizontalAlignment="Center"
                                                               Text="{Binding StatusText}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Style="{StaticResource AppCaptionTextStyle}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1"
                                        Margin="0,14,0,0"
                                        Padding="14,12"
                                        Background="{StaticResource AppSurfaceRaisedBrush}"
                                        BorderBrush="{StaticResource AppBorderBrush}"
                                        BorderThickness="0,1,0,0"
                                        CornerRadius="0,0,14,14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Margin="0,0,8,0"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Style="{StaticResource AppBodyTextStyle}"
                                                   ToolTip="{Binding StatusMessage}"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding LastUpdated, StringFormat='{}{0:HH:mm:ss}', TargetNullValue=Нет обновлений}"
                                                   Style="{StaticResource AppCaptionTextStyle}"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,8,0,0"
                                                    Orientation="Horizontal">
                                            <Ellipse Style="{StaticResource StatusIndicatorStyle}"/>
                                            <TextBlock Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding StatusText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{StaticResource AppCaptionTextStyle}"
                                                       ToolTip="{Binding StatusMessage}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
